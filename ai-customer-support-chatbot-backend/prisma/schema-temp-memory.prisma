model UserMemory {
  id           String    @id @default(uuid())
  userId       String
  memoryType   String    // e.g., "candidate", "employer", "behavioral"
  memoryKey    String    // e.g., "role", "experience", "companyName"
  memoryValue  Json      
  confidence   Float     @default(1)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_memories")
}
